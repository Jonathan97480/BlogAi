# Clé API pour l'IA (à personnaliser)
IA_API_KEY=ma_cle_api_super_secrete
# Exemple de variables d'environnement backend
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=azerty
DB_NAME=blog_ai_tech
JWT_SECRET=une_chaine_secrete
LOG_ERRORS=true
BASE_URL=http://localhost
PORT=5000

# Pool de connexions MySQL
DB_CONNECTION_LIMIT=10   # connexions simultanées max (défaut: 10)
DB_QUEUE_LIMIT=0         # taille file SQL, 0 = illimitée (défaut: 0)

# File d'attente IA (routes /api/ia/enrich et /api/v1/IaOptimiseText)
IA_CONCURRENCY=2         # appels IA simultanés max (défaut: 2)
IA_QUEUE_MAX=20          # taille max de la file IA (défaut: 20)
IA_QUEUE_TIMEOUT=60000   # timeout d'attente en ms (défaut: 60000 = 60s)

# File d'attente uploads (routes /api/upload et /api/v1/uploadImage)
UPLOAD_CONCURRENCY=3     # uploads simultanés max (défaut: 3)
UPLOAD_QUEUE_MAX=10      # taille max de la file upload (défaut: 10)
UPLOAD_QUEUE_TIMEOUT=30000 # timeout d'attente en ms (défaut: 30000 = 30s)